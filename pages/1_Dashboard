import streamlit as st
import plotly.express as px
from src.data_processing import load_and_process_data

st.set_page_config(page_title="Dashboard | Hackathon", page_icon="📊", layout="wide")

st.title("📊 Dashboard de Monitoreo Solar")

# 1. Carga de datos ultra-rápida gracias a @st.cache_data
# La primera vez tardará, las siguientes será instantáneo.
df = load_and_process_data()

if not df.empty:
    st.write(f"**Registros analizados:** {len(df):,}")
    
    # 2. Métricas rápidas
    col1, col2, col3 = st.columns(3)
    col1.metric("Temperatura Promedio", f"{df['Temperatura_C'].mean():.1f} °C")
    col2.metric("Humedad Promedio", f"{df['Humedad_%'].mean():.1f} %")
    col3.metric("Total Anomalías Históricas", f"{df['Anomalia'].sum():,}")

    st.markdown("---")

    # 3. Gráficas optimizadas (usamos un sample si es muy grande para no trabar el navegador)
    st.subheader("Tendencia de Temperatura vs Humedad")
    
    # Tomamos una muestra de 2000 datos para graficar rápido sin colapsar el frontend
    df_sample = df.sample(n=2000, random_state=42) if len(df) > 2000 else df
    
    fig = px.scatter(
        df_sample, 
        x="Temperatura_C", 
        y="Humedad_%", 
        color="Anomalia",
        color_continuous_scale="Reds",
        title="Mapeo de Anomalías (Muestra representativa)"
    )
    st.plotly_chart(fig, use_container_width=True)
else:
    st.warning("No se pudieron cargar los datos. Verifica el archivo CSV.")
