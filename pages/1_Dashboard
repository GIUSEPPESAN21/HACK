import streamlit as st
import pandas as pd
import plotly.express as px
import plotly.graph_objects as go
import os

# 1. Configuración de página
st.set_page_config(
    page_title="Dashboard Solar | SAVA",
    page_icon="📊",
    layout="wide",
    initial_sidebar_state="expanded"
)

# 2. Inyección de CSS para tarjetas y métricas
